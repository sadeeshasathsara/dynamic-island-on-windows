<Application x:Class="DynamicIslandNotifier.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Tray Icon -->
            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="/Assets/island.ico"
                            ToolTipText="Dynamic Island Notifier">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Dynamic Island Notifier" IsEnabled="False" FontWeight="Bold"/>
                        <Separator/>
                        <MenuItem Header="Enable / Disable" Click="Toggle_Click"/>
                        <Separator/>
                        <MenuItem Header="Quit" Click="Quit_Click"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
